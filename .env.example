# Copy to .env and fill in. scripts/deploy.sh auto-detects:
#   creds present  → API upload (zero clicks)
#   creds absent   → opens the store tab (drag the zip)
# .env is gitignored — never committed.

# ── Firefox AMO ──────────────────────────────────────────────
# Get from: https://addons.mozilla.org/developers/ → API Keys (free, instant)
WEB_EXT_API_KEY=
WEB_EXT_API_SECRET=
# 'listed' = public on AMO, 'unlisted' = signed xpi for self-distribution
WEB_EXT_CHANNEL=listed

# ── Chrome Web Store ─────────────────────────────────────────
# One-time Google Cloud OAuth setup (~10 min):
#   https://github.com/DrewML/chrome-webstore-upload/blob/master/How-to-get-OAuth-CLI-credentials.md
CLIENT_ID=
CLIENT_SECRET=
REFRESH_TOKEN=
# The extension's ID from the Web Store listing URL
EXTENSION_ID=
